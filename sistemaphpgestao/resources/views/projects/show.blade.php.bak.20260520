    $totalMetas     = $project->goals->count();

    // Aba inicial selecionável via query string ?tab=...
    $tabsValid = ['info','despesas','metas','comprovacao','diligencias','prestacao','relatorio','compliance'];
    $activeTab = in_array(request('tab'), $tabsValid, true) ? request('tab') : 'info';

    $sel = $project->reportSelection;
    $relSel = [
        'inc_informacoes'      => $sel->inc_informacoes      ?? true,
        'inc_despesas'         => $sel->inc_despesas         ?? true,
