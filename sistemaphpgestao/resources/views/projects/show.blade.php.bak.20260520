@push('scripts')
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // "Selecionar Tudo" no relatório
        const selAll = document.getElementById('selAll');
        const opts = document.querySelectorAll('.rel-sel');
        function syncSelAll() {
            const all = Array.from(opts).every(o => o.checked);
            if (selAll) selAll.checked = all;
        }
        if (selAll) {
            selAll.addEventListener('change', () => {
                opts.forEach(o => o.checked = selAll.checked);
            });
            opts.forEach(o => o.addEventListener('change', syncSelAll));
            syncSelAll();
        }

        // "Selecionar Tudo" no compliance
        const selAllComp = document.getElementById('selAllComp');
        const optsComp = document.querySelectorAll('.comp-sel');
        function syncSelAllComp() {
            const all = Array.from(optsComp).every(o => o.checked);
            if (selAllComp) selAllComp.checked = all;
        }
        if (selAllComp) {
            selAllComp.addEventListener('change', () => {
                optsComp.forEach(o => o.checked = selAllComp.checked);
            });
            optsComp.forEach(o => o.addEventListener('change', syncSelAllComp));
            syncSelAllComp();
        }
    });

    function deleteProofPhoto(projectId, goalId, idx) {
        if (!confirm('Excluir esta foto?')) return;
        const fd = new FormData();
        fd.append('_token', document.querySelector('meta[name="csrf-token"]').content);
        fd.append('_method', 'DELETE');
        fd.append('index', idx);
        fetch(`/projetos/${projectId}/metas/${goalId}/comprovacao/foto`, {
            method: 'POST',
            body: fd
        }).then(() => window.location.reload());
    }

    function deleteProofAttachment(projectId, goalId) {
        if (!confirm('Excluir este anexo?')) return;
        const fd = new FormData();
        fd.append('_token', document.querySelector('meta[name="csrf-token"]').content);
        fd.append('_method', 'DELETE');
        fetch(`/projetos/${projectId}/metas/${goalId}/comprovacao/anexo`, {
            method: 'POST',
            body: fd
        }).then(() => window.location.reload());
    }

    function generateReportPdf(projectId) {
        const params = new URLSearchParams();
        document.querySelectorAll('.rel-sel:checked').forEach(o => params.append(o.name, '1'));
        window.location = `/projetos/${projectId}/relatorio/pdf?` + params.toString();
    }

    function generateCompliancePdf(projectId) {
        const params = new URLSearchParams();
        document.querySelectorAll('.comp-sel:checked').forEach(o => params.append(o.name, '1'));
        window.location = `/projetos/${projectId}/compliance/pdf?` + params.toString();
    }
</script>
@endpush

@endsection
