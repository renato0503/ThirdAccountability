        'inc_diligencias'      => $sel->inc_diligencias      ?? true,
        'inc_prestacao_contas' => $sel->inc_prestacao_contas ?? true,
    ];

    $compSel = $project->complianceSelection;
    $compliance = [
        'inc_informacoes'      => $compSel->inc_informacoes      ?? true,
        'inc_despesas'         => $compSel->inc_despesas         ?? false,
        'inc_metas'            => $compSel->inc_metas            ?? false,
